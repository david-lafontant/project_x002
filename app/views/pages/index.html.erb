<div class="mb-5 splash">
  <div class="p-5 text-center">
    <div class="container py-5">
      <h1 class="text-body-emphasis azul">Full-width jumbotron</h1>
      <p class="col-lg-8 mx-auto lead azul">
        This takes the basic jumbotron above and makes its background edge-to-edge with a <code>.container</code> inside to align content. Similar to above, it&apos;s been recreated with built-in grid and utility classes.
      </p>
    </div>
  </div>
</div>
<div class="container my-5">
  <div class="p-5 text-center bg-body-tertiary rounded-3">
    <%= image_tag("armoirie.jpeg", width: "100", class:  "image-fluid mt-4 mb-3" )%>
    <h1 class="text-body-emphasis">Jumbotron with icon</h1>
    <p class="col-lg-8 mx-auto fs-5 text-muted">
      This is a custom jumbotron featuring an SVG image at the top, some longer text that wraps early thanks to a responsive <code>.col-*</code> class, and a customized call to action.
    </p>
    <div class="d-inline-flex gap-2 mb-5">
      <button class="d-inline-flex align-items-center btn btn-primary btn-lg px-4 rounded-pill" type="button">
        Call to action
        <svg class="bi ms-2" width="24" height="24"><use xlink:href="#arrow-right-short"/></svg>
        
      </button>
      <button class="btn btn-outline-secondary btn-lg px-4 rounded-pill" type="button">
        Secondary link
      </button>
    </div>
  </div>
</div>